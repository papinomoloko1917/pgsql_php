<?php

declare(strict_types=1);

require __DIR__ . '/vendor/autoload.php';

$filePath = $argv[0];
$command = $argv[1];

switch ($command) {
    case 'migrate':
        require_once __DIR__ . '/bin/migration.php';
        break;
    case 'seed':
        require_once __DIR__ . '/bin/seeder.php';
        break;
    default:
        echo "Неизвестная команда: $command\n";
        echo "Доступные команды: migrate, seed\n";
        exit(1);
}
